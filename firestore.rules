rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funkcja pomocnicza sprawdzająca czy użytkownik jest zalogowany
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Funkcja pomocnicza sprawdzająca czy użytkownik jest właścicielem dokumentu
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEventOwner(eventId) {
      return isAuthenticated() && (
        // Dla istniejących dokumentów
        (exists(/databases/$(database)/documents/events/$(eventId)) &&
        get(/databases/$(database)/documents/events/$(eventId)).data.userId == request.auth.uid) ||
        // Dla nowych dokumentów
        (request.resource != null && request.resource.data.eventId == eventId)
      );
    }

    // Reguły dla kolekcji events
    match /events/{eventId} {
      // Pozwól na odczyt wydarzenia dla wszystkich (potrzebne do potwierdzania obecności)
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Reguły dla kolekcji guests
    match /guests/{guestId} {
      // Pozwól na odczyt dokumentu gościa bez autoryzacji (potrzebne do potwierdzania obecności)
      allow read: if true;
      
      // Pozwól na aktualizację statusu gościa bez autoryzacji
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'notes', 'updatedAt']);
      
      // Pozwól na pełne zarządzanie gośćmi tylko dla zalogowanych właścicieli
      allow create: if isAuthenticated() && isEventOwner(request.resource.data.eventId);
      allow delete: if isAuthenticated() && isEventOwner(resource.data.eventId);
    }

    // Reguły dla kolekcji subscriptions
    match /subscriptions/{subscriptionId} {
      // Pozwól na odczyt subskrypcji dla zalogowanych użytkowników
      allow read: if isAuthenticated();
      // Pozwól na aktualizację tylko właścicielowi
      allow update: if isOwner(resource.data.userId);
      // Pozwól na tworzenie nowej subskrypcji dla zalogowanego użytkownika
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}